{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "D:\\msys2\\mingw64\\bin\\gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-O2",
                "-Iinclude",
                "-o",
                "bin/cf-analyzer.exe",
                "src/main.c",
                "src/cJSON.c",
                "-lcurl"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true 
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "D:/msys2/mingw64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "D:/msys2/mingw64/bin"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": false  // 改为 false
            },
            "detail": "调试器生成的任务。"
        }
    ]
}